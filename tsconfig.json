{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2024"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node", "vscode"],
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "*.ts"
  ]
}
