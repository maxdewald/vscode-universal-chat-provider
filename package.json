{
  "publisher": "maxdewald",
  "name": "modelprovider",
  "displayName": "Model Provider",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "volta": {
    "node": "24.16.0",
    "pnpm": "11.6.0"
  },
  "description": "A VS Code extension for model provider integrations.",
  "author": "Maximilian Dewald <maximilian@dewald.one>",
  "license": "MIT",
  "homepage": "https://github.com/maxdewald/modelprovider#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxdewald/modelprovider.git"
  },
  "bugs": {
    "url": "https://github.com/maxdewald/modelprovider/issues"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.cjs",
  "icon": "res/icon.png",
  "files": [
    "LICENSE.md",
    "dist/*",
    "res/*"
  ],
  "engines": {
    "node": ">=22.18.0",
    "vscode": "^1.120.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [],
    "configuration": {
      "type": "object",
      "title": "Model Provider",
      "properties": {}
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --sourcemap",
    "prepare": "pnpm generate",
    "generate": "vscode-ext-gen --output src/generated/meta.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "vscode:prepublish": "pnpm build",
    "release": "bumpp",
    "ext:package": "vsce package --no-dependencies",
    "ext:publish": "vsxpub --no-dependencies"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^24.13.2",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "ovsx": "^1.0.1",
    "reactive-vscode": "^1.0.2",
    "taze": "^19.14.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vscode-ext-gen": "^1.6.0",
    "vsxpub": "^0.1.4"
  }
}
