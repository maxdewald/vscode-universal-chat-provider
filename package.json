{
  "publisher": "maxdewald",
  "name": "universal-chat-provider",
  "displayName": "Universal Chat Provider",
  "type": "module",
  "version": "0.20.1",
  "packageManager": "pnpm@11.14.0",
  "volta": {
    "node": "24.18.0",
    "pnpm": "11.14.0"
  },
  "description": "Claude, Codex, Antigravity & more in GitHub Copilot Chat. No API key, just OAuth.",
  "author": "Maximilian Dewald <maximilian@dewald.one>",
  "license": "MIT",
  "homepage": "https://github.com/maxdewald/vscode-universal-chat-provider#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxdewald/vscode-universal-chat-provider.git"
  },
  "bugs": {
    "url": "https://github.com/maxdewald/vscode-universal-chat-provider/issues"
  },
  "keywords": [
    "language-models"
  ],
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./dist/index.cjs",
  "icon": "images/logo.png",
  "files": [
    "LICENSE.md",
    "dist/*",
    "images/logo.png"
  ],
  "engines": {
    "node": ">=22.18.0",
    "vscode": "^1.124.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "universal-chat-provider",
        "displayName": "Universal Chat Provider",
        "managementCommand": "universalChatProvider.login"
      }
    ],
    "commands": [
      {
        "command": "universalChatProvider.manage",
        "title": "Universal Chat Provider: Manage Provider"
      },
      {
        "command": "universalChatProvider.login",
        "title": "Universal Chat Provider: Add Account (Login)"
      },
      {
        "command": "universalChatProvider.manageAccounts",
        "title": "Universal Chat Provider: Manage Accounts"
      },
      {
        "command": "universalChatProvider.showQuota",
        "title": "Universal Chat Provider: Show Quota"
      },
      {
        "command": "universalChatProvider.restartServer",
        "title": "Universal Chat Provider: Restart Managed Server"
      },
      {
        "command": "universalChatProvider.updateBinary",
        "title": "Universal Chat Provider: Update Proxy Binary"
      },
      {
        "command": "universalChatProvider.resetServer",
        "title": "Universal Chat Provider: Reset Managed Server"
      },
      {
        "command": "universalChatProvider.configure",
        "title": "Universal Chat Provider: Configure Connection"
      },
      {
        "command": "universalChatProvider.importConfig",
        "title": "Universal Chat Provider: Import API Key from Config"
      },
      {
        "command": "universalChatProvider.refresh",
        "title": "Universal Chat Provider: Refresh Models"
      },
      {
        "command": "universalChatProvider.setUtilityModel",
        "title": "Universal Chat Provider: Set Utility Model (commit messages, chat titles, summaries)"
      },
      {
        "command": "universalChatProvider.clearCredentials",
        "title": "Universal Chat Provider: Clear Stored API Key"
      },
      {
        "command": "universalChatProvider.showLogs",
        "title": "Universal Chat Provider: Show Logs"
      },
      {
        "command": "universalChatProvider.showServerLogs",
        "title": "Universal Chat Provider: Show Server Output"
      },
      {
        "command": "universalChatProvider.openSettings",
        "title": "Universal Chat Provider: Open Settings"
      }
    ],
    "configuration": [
      {
        "type": "object",
        "title": "Connection",
        "order": 1,
        "properties": {
          "universalChatProvider.server.mode": {
            "type": "string",
            "enum": [
              "managed",
              "external"
            ],
            "enumItemLabels": [
              "Managed",
              "External"
            ],
            "enumDescriptions": [
              "Download and run CLIProxyAPI automatically.",
              "Connect to a CLIProxyAPI server you manage."
            ],
            "default": "managed",
            "order": 1,
            "description": "How CLIProxyAPI is provided."
          },
          "universalChatProvider.baseUrl": {
            "type": "string",
            "default": "http://127.0.0.1:8317",
            "order": 2,
            "description": "CLIProxyAPI server URL. Used only in external mode.",
            "markdownDescription": "CLIProxyAPI server URL. Used only when `#universalChatProvider.server.mode#` is `external`."
          },
          "universalChatProvider.configPath": {
            "type": "string",
            "default": "",
            "order": 3,
            "description": "Optional CLIProxyAPI config.yaml path for credential and model metadata discovery.",
            "markdownDescription": "Optional CLIProxyAPI `config.yaml` path for credential and model metadata discovery."
          },
          "universalChatProvider.autoDetectConfig": {
            "type": "boolean",
            "default": true,
            "order": 4,
            "description": "Search common CLIProxyAPI config locations when no config path is set."
          }
        }
      },
      {
        "type": "object",
        "title": "Managed Server",
        "order": 2,
        "properties": {
          "universalChatProvider.server.updatePolicy": {
            "type": "string",
            "enum": [
              "automatic",
              "suggestUpdates",
              "manual"
            ],
            "enumItemLabels": [
              "Automatic",
              "Suggest Updates",
              "Manual"
            ],
            "enumDescriptions": [
              "Install the latest stable CLIProxyAPI release when VS Code starts.",
              "Check for stable updates when VS Code starts and ask before installing.",
              "Use only the configured version and do not check for updates."
            ],
            "default": "automatic",
            "scope": "machine",
            "order": 1,
            "description": "How managed CLIProxyAPI updates are handled."
          },
          "universalChatProvider.server.version": {
            "type": "string",
            "default": "7.2.5",
            "scope": "machine",
            "order": 2,
            "description": "Exact CLIProxyAPI release used when update policy is Manual.",
            "markdownDescription": "Exact CLIProxyAPI release used when `#universalChatProvider.server.updatePolicy#` is `manual`."
          }
        }
      },
      {
        "type": "object",
        "title": "Status Bar",
        "order": 3,
        "properties": {
          "universalChatProvider.showQuotaWarnings": {
            "type": "boolean",
            "default": true,
            "order": 1,
            "description": "Warn in the status bar when the model in use is low on quota."
          },
          "universalChatProvider.quotaWarningThreshold": {
            "type": "number",
            "default": 10,
            "minimum": 0,
            "maximum": 100,
            "order": 2,
            "description": "Remaining-quota percent below which the status bar warning appears."
          }
        }
      },
      {
        "type": "object",
        "title": "Advanced",
        "order": 5,
        "properties": {
          "universalChatProvider.debug": {
            "type": "boolean",
            "default": false,
            "order": 1,
            "description": "Show prompt-cache hit rate and write per-request diagnostics to extension storage."
          }
        }
      }
    ]
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --sourcemap",
    "prepare": "pnpm generate",
    "generate": "vscode-ext-gen --output src/generated/meta.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build",
    "vscode:prepublish": "pnpm build",
    "ext:package": "vsce package --no-dependencies",
    "ext:publish": "vsce publish --no-dependencies"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.52",
    "eventsource-parser": "^3.1.0",
    "fflate": "^0.8.3",
    "get-port": "^7.2.0",
    "ky": "^2.0.2",
    "moderndash": "^4.0.2",
    "nanotar": "^0.3.0",
    "semver": "^7.8.4",
    "tokenx": "^1.3.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.13.2",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.124.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.7.0",
    "jest-mock-vscode": "^4.12.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vscode-ext-gen": "^1.6.0"
  }
}
